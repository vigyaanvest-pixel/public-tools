{
  "manifest_version": 3,
  "name": "Symbol 360",
  "description": "Full-circle local stock research — watchlist, thesis notes, and page enrichment in your sidebar.",
  "version": "0.1.1",
  "action": {
    "default_title": "Symbol 360",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "src/sidebar-panel/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-Czmy5UXR.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://finance.yahoo.com/*",
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://www.nseindia.com/*",
    "https://www.screener.in/*",
    "https://www.sec.gov/*",
    "https://finviz.com/*",
    "https://www.tradingview.com/*",
    "https://s3.tradingview.com/*"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/symbol-resolver-CSQ3qyHS.js",
        "assets/AppContext-B0gPBFGd.js",
        "assets/index-DL1U5nUp.js",
        "assets/index.ts-DTKMwEE_.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
